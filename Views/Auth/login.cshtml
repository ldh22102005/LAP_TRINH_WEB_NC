@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập | Specialized Bike Store</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-color: #e74c3c; /* Màu đỏ thể thao đặc trưng của các dòng xe đua */
            --dark-color: #2c3e50;
            --accent-color: #f1c40f;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            /* Thay URL hình ảnh bằng hình nền xe đạp chất lượng cao */
            /* Đoạn mã mới (đường dẫn nội bộ) */
            background: 
            linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)),
            url('/images/login.jpg');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-container {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(15px); /* Hiệu ứng kính mờ hiện đại */
            border: 1px solid rgba(255, 255, 255, 0.2);
            padding: 40px;
            width: 100%;
            max-width: 400px;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
            color: white;
            text-align: center;
        }

        .logo-icon {
            font-size: 50px;
            color: var(--primary-color);
            margin-bottom: 10px;
            filter: drop-shadow(0 0 10px rgba(231, 76, 60, 0.5));
        }

        h2 {
            margin: 0 0 10px 0;
            font-size: 28px;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 800;
        }

        p.subtitle {
            margin-bottom: 30px;
            font-size: 14px;
            opacity: 0.8;
        }

        .input-group {
            position: relative;
            margin-bottom: 20px;
        }

        .input-group i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #ddd;
        }

        input {
            width: 100%;
            padding: 12px 15px 12px 45px;
            box-sizing: border-box;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 30px;
            color: white;
            outline: none;
            transition: 0.3s;
            font-size: 15px;
        }

        input::placeholder {
            color: #ccc;
        }

        input:focus {
            background: rgba(255, 255, 255, 0.2);
            border-color: var(--primary-color);
            box-shadow: 0 0 10px rgba(231, 76, 60, 0.3);
        }

        button {
            width: 100%;
            padding: 12px;
            margin-top: 10px;
            border: none;
            border-radius: 30px;
            background: var(--primary-color);
            color: white;
            font-size: 16px;
            font-weight: bold;
            text-transform: uppercase;
            cursor: pointer;
            transition: 0.4s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        button:hover {
            background: #c0392b;
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(231, 76, 60, 0.4);
        }

        .error-msg {
            color: #ff6b6b;
            font-size: 14px;
            margin-top: 15px;
            min-height: 20px;
        }

        .footer-links {
            margin-top: 25px;
            border-top: 1px solid rgba(255, 255, 255, 0.2);
            padding-top: 20px;
        }

        .footer-links a {
            color: white;
            text-decoration: none;
            font-size: 14px;
            transition: 0.3s;
        }

        .footer-links a:hover {
            color: var(--accent-color);
        }

        /* Hiệu ứng chuyển động nhẹ */
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .login-container {
            animation: fadeIn 0.8s ease-out;
        }
    </style>
</head>
<body>

    <div class="login-container">
        <div class="logo-icon">
            <i class="fas fa-bicycle"></i>
        </div>
        <h2>BIKE WORLD</h2>
        <p class="subtitle">Sẵn sàng cho những hành trình mới</p>

        <form method="post">
            <div class="input-group">
                <i class="fas fa-user"></i>
                <input name="username" type="text" placeholder="Tên đăng nhập" required />
            </div>
            
            <div class="input-group">
                <i class="fas fa-lock"></i>
                <input name="password" type="password" placeholder="Mật khẩu" required />
            </div>

            <button type="submit">
                Đăng nhập <i class="fas fa-arrow-right"></i>
            </button>
        </form>

        <div class="error-msg">
            @ViewBag.Error
        </div>

        <div class="footer-links">
            <a href="/Auth/Register">Chưa có tài khoản? <strong>Đăng ký ngay</strong></a>
            <br><br>
            <a href="#" style="opacity: 0.6; font-size: 12px;">Quên mật khẩu?</a>
        </div>
    </div>

</body>
</html>