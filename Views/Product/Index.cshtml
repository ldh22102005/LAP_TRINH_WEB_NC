@model List<QL_CUA_HANG_BAN_XE_DAP.Models.Product>

<style>
    /* 1. KHUNG CHỨA CHÍNH */
    .main-content {
        max-width: 1200px;
        margin: 30px auto;
        padding: 0 15px;
    }

    /* 2. TIÊU ĐỀ TRANG (Đã căn giữa) */
    .page-title { 
        font-size: 28px; 
        font-weight: 700; 
        margin-bottom: 35px; 
        text-align: center; /* Căn giữa tiêu đề */
        color: #1a1a1a;
        text-transform: uppercase;
        position: relative;
        padding-bottom: 15px;
    }

    /* Tạo gạch chân nhỏ dưới tiêu đề cho đẹp */
    .page-title::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 60px;
        height: 3px;
        background: #3b39fd; /* Màu xanh chủ đạo */
    }

    /* 3. LƯỚI SẢN PHẨM (Grid) */
    .product-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr); /* Đổi thành 4 cột cho chuyên nghiệp */
        gap: 25px;
    }

    /* 4. THẺ SẢN PHẨM (Card) */
    .product-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        text-decoration: none;
        color: #333;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        border: 1px solid #f0f0f0;
    }

    .product-card:hover { 
        transform: translateY(-8px); 
        box-shadow: 0 10px 25px rgba(0,0,0,0.1); 
        border-color: #3b39fd;
    }

    /* Ảnh sản phẩm */
    .product-card img { 
        width: 100%; 
        height: 200px; 
        object-fit: cover; 
        transition: transform 0.5s ease;
    }
    
    .product-card:hover img {
        transform: scale(1.05);
    }

    /* Thông tin chữ */
    .info { 
        padding: 15px; 
        text-align: center; /* Căn giữa tên và giá */
    }

    .info .name { 
        font-size: 15px; 
        font-weight: 600;
        margin-bottom: 10px; 
        line-height: 1.4;
        height: 42px; /* Giới hạn độ cao để các card đều nhau */
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .price { 
        color: #e74c3c; /* Màu đỏ nổi bật cho giá tiền */
        font-weight: 700; 
        font-size: 17px; 
    }

    /* 5. THÔNG BÁO TRỐNG */
    .empty-state {
        text-align: center;
        color: #999;
        margin-top: 50px;
        font-size: 1.1rem;
    }

    /* Responsive cho điện thoại */
    @@media (max-width: 992px) {
        .product-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @@media (max-width: 768px) {
        .product-grid { grid-template-columns: repeat(2, 1fr); }
    }
</style>

<div class="main-content">
    
    <h1 class="page-title">
        @(ViewBag.CategoryName ?? "Danh sách sản phẩm")
    </h1>

    <div class="product-grid">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <a href="/Product/Detail/@item.Id" class="product-card">
                    <img src="@item.Image" alt="@item.Name" />
                    <div class="info">
                        <div class="name">@item.Name</div>
                        <div class="price">@item.Price.ToString("N0") VNĐ</div>
                    </div>
                </a>
            }
        }
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <i class="fas fa-box-open" style="font-size: 3rem; margin-bottom: 15px;"></i>
            <p>Hiện tại không có sản phẩm nào trong danh mục này.</p>
        </div>
    }
</div>