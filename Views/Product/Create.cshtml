@model QL_CUA_HANG_BAN_XE_DAP.Models.Product

<h2>Thêm sản phẩm</h2>

<form method="post">
    <input name="Name" placeholder="Tên sản phẩm" required /><br /><br />

    <input name="Price" placeholder="Giá" required /><br /><br />

    <input name="Image" placeholder="/images/abc.jpg" required /><br /><br />

    <input name="Description" placeholder="Mô tả" /><br /><br />

    <input name="CategoryId" placeholder="CategoryId" /><br /><br />

    <button type="submit">Thêm</button>
</form>