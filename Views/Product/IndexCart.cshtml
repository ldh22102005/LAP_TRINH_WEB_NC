@model List<QL_CUA_HANG_BAN_XE_DAP.Models.Product>

<style>
    .main-content {
        max-width: 1200px;
        margin: 30px auto;
        padding: 0 15px;
    }

    .page-title {
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 35px;
        text-align: center;
        color: #1a1a1a;
        text-transform: uppercase;
        position: relative;
        padding-bottom: 15px;
    }

    .page-title::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 60px;
        height: 3px;
        background: #3b39fd;
    }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 25px;
    }

    .product-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        color: #333;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        border: 1px solid #f0f0f0;
    }

    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        border-color: #3b39fd;
    }

    .product-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .product-card img {
        width: 100%;
        height: 200px;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .product-card:hover img {
        transform: scale(1.05);
    }

    .info {
        padding: 15px;
        text-align: center;
    }

    .info .name {
        font-size: 15px;
        font-weight: 600;
        margin-bottom: 10px;
        line-height: 1.4;
        height: 42px;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .price {
        color: #e74c3c;
        font-weight: 700;
        font-size: 17px;
    }

    .card-actions {
        padding: 0 15px 15px;
        display: flex;
        gap: 10px;
    }

    .card-actions form,
    .card-actions a {
        flex: 1;
    }

    .btn-detail,
    .btn-cart {
        width: 100%;
        border: none;
        border-radius: 10px;
        padding: 10px 12px;
        text-align: center;
        font-weight: 600;
        text-decoration: none;
    }

    .btn-detail {
        background: #eef2ff;
        color: #312e81;
    }

    .btn-cart {
        background: #3b39fd;
        color: #fff;
        cursor: pointer;
    }

    .empty-state {
        text-align: center;
        color: #999;
        margin-top: 50px;
        font-size: 1.1rem;
    }

    @@media (max-width: 992px) {
        .product-grid { grid-template-columns: repeat(3, 1fr); }
    }

    @@media (max-width: 768px) {
        .product-grid { grid-template-columns: repeat(2, 1fr); }
    }
</style>

<div class="main-content">
    <h1 class="page-title">
        @(ViewBag.CategoryName ?? "Danh sách sản phẩm")
    </h1>

    <div class="product-grid">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="product-card">
                    <a href="/Product/Detail/@item.Id" class="product-link">
                        <img src="@item.Image" alt="@item.Name" />
                        <div class="info">
                            <div class="name">@item.Name</div>
                            <div class="price">@item.Price.ToString("N0") VNĐ</div>
                        </div>
                    </a>

                    <div class="card-actions">
                        <a href="/Product/Detail/@item.Id" class="btn-detail">Chi tiết</a>
                        <form method="post" action="/Cart/AddToCart">
                            <input type="hidden" name="productId" value="@item.Id" />
                            <input type="hidden" name="quantity" value="1" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            <button type="submit" class="btn-cart">Thêm giỏ</button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <p>Hiện tại không có sản phẩm nào trong danh mục này.</p>
        </div>
    }
</div>
