@model List<QL_CUA_HANG_BAN_XE_DAP.Models.Product>

@{
    Layout = "_Layout";
}

<style>
    :root {
        --primary-color: #3b39fd;
        --secondary-color: #e74c3c;
        --bg-light: #f8f9fa;
        --transition: all 0.3s ease;
    }

    /* --- 1. BANNER SLIDER (FULL SCREEN WIDTH) --- */
    .hero-slider {
        /* Kỹ thuật tràn lề sát mép màn hình */
        width: 100vw; 
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
        
        overflow: hidden;
        background-color: #e0f2fe;
        /* Tỷ lệ vàng cho banner web (rộng 3, cao 1) - giúp không bị quá cao */
        aspect-ratio: 3 / 1; 
    }

    .slider-container {
        display: flex;
        height: 100%;
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .slide {
        min-width: 100%;
        height: 100%;
        position: relative;
    }

    .slide img {
        width: 100%;
        height: 100%;
        display: block;
        /* Quan trọng: giúp ảnh lấp đầy khung mà không bị móp méo */
        object-fit: cover; 
    }

    .slider-dots {
        position: absolute;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 10px;
        z-index: 10;
    }

    .dot {
        width: 12px;
        height: 12px;
        background: rgba(255,255,255,0.5);
        border-radius: 50%;
        cursor: pointer;
        transition: var(--transition);
    }

    .dot.active { 
        background: white; 
        width: 30px; 
        border-radius: 10px; 
    }

    /* --- 2. NỘI DUNG CHÍNH (GIỮ TRONG KHUNG GIỮA) --- */
    .main-content {
        max-width: 1250px; /* Rộng hơn một chút cho sang */
        margin: 40px auto;
        padding: 0 15px;
    }

    .page-title { 
        font-size: 28px; 
        font-weight: 700; 
        margin-bottom: 40px; 
        text-align: center; 
        text-transform: uppercase;
        position: relative;
        padding-bottom: 15px;
    }

    .page-title::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 60px;
        height: 3px;
        background: var(--primary-color);
    }

    /* --- 3. LƯỚI SẢN PHẨM --- */
    .product-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 25px;
    }

    .product-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 3px 10px rgba(0,0,0,0.05);
        text-decoration: none;
        color: #333;
        transition: var(--transition);
        border: 1px solid #eee;
        display: flex;
        flex-direction: column;
    }

    .product-card:hover { 
        transform: translateY(-7px); 
        box-shadow: 0 10px 20px rgba(0,0,0,0.12); 
        border-color: var(--primary-color);
    }

    .product-card img { 
        width: 100%; 
        height: 220px; 
        object-fit: cover; 
    }

    .info { padding: 15px; text-align: center; flex-grow: 1; }

    .info .name { 
        font-size: 15px; 
        font-weight: 600;
        height: 42px;
        overflow: hidden;
        margin-bottom: 10px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .price { color: var(--secondary-color); font-weight: 700; font-size: 17px; }

    /* --- 4. NÚT LIÊN HỆ BÊN PHẢI --- */
    .sticky-contact {
        position: fixed;
        right: 15px;
        top: 60%;
        display: flex;
        flex-direction: column;
        gap: 12px;
        z-index: 9999;
    }

    .contact-btn {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        text-decoration: none;
        font-size: 22px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        transition: var(--transition);
    }

    .contact-btn:hover { transform: scale(1.15); }
    .zalo { background: #0068ff; }
    .messenger { background: #0084ff; }
    .phone { background: #2ecc71; }

    /* Responsive */
    @@media (max-width: 992px) { 
        .product-grid { grid-template-columns: repeat(2, 1fr); } 
        .hero-slider { aspect-ratio: 16 / 9; } /* Trên mobile để banner cao hơn tí dễ nhìn */
    }
    @@media (max-width: 576px) { .product-grid { grid-template-columns: 1fr; } }
</style>

<section class="hero-slider">
    <div class="slider-container" id="slider">
        <div class="slide">
            <img src="/images/Home/banner1.png" alt="Banner 1">
        </div>
        <div class="slide">
            <img src="/images/Home/banner2.png" alt="Banner 2">
        </div>
        <div class="slide">
            <img src="/images/Home/banner3.png" alt="Banner 3">
        </div>
        <div class="slide">
            <img src="/images/Home/banner4.png" alt="Banner 4">
        </div>
    </div>
    
    <div class="slider-dots">
        <span class="dot active" onclick="currentSlide(0)"></span>
        <span class="dot" onclick="currentSlide(1)"></span>
        <span class="dot" onclick="currentSlide(2)"></span>
        <span class="dot" onclick="currentSlide(3)"></span>
    </div>
</section>

<div class="main-content">
    <h1 class="page-title">@(ViewBag.CategoryName ?? "Sản phẩm mới nhất")</h1>

    <div class="product-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <a href="/Product/Detail/@item.Id" class="product-card">
                    <img src="@item.Image" alt="@item.Name" />
                    <div class="info">
                        <div class="name">@item.Name</div>
                        <div class="price">@item.Price.ToString("N0") VNĐ</div>
                    </div>
                </a>
            }
        }
        else
        {
            <p style="text-align:center; grid-column: 1/-1;">Hiện chưa có sản phẩm nào.</p>
        }
    </div>
</div>

<div class="sticky-contact">
    <a href="#" class="contact-btn zalo" title="Zalo"><i class="fas fa-comment-dots"></i></a>
    <a href="#" class="contact-btn messenger" title="Messenger"><i class="fab fa-facebook-messenger"></i></a>
    <a href="tel:0123456789" class="contact-btn phone" title="Gọi điện"><i class="fas fa-phone"></i></a>
</div>

<script>
    let index = 0;
    const slidesContainer = document.getElementById('slider');
    const dots = document.querySelectorAll('.dot');
    const totalSlides = dots.length;

    function showSlide(n) {
        index = n;
        if (index >= totalSlides) index = 0;
        if (index < 0) index = totalSlides - 1;
        
        slidesContainer.style.transform = `translateX(${-index * 100}%)`;
        
        dots.forEach(d => d.classList.remove('active'));
        dots[index].classList.add('active');
    }

    let autoSlide = setInterval(() => {
        showSlide(index + 1);
    }, 4000);

    function currentSlide(n) {
        clearInterval(autoSlide);
        showSlide(n);
        autoSlide = setInterval(() => {
            showSlide(index + 1);
        }, 4000);
    }
</script>