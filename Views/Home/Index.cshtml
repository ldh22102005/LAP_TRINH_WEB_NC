@model List<QL_CUA_HANG_BAN_XE_DAP.Models.Product>
@using System.Linq

@{
    Layout = "_Layout";
}

<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css"/>
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css"/>

<style>
    :root {
        --primary-color: #3b39fd;
        --secondary-color: #e74c3c;
        --bg-light: #f8f9fa;
        --transition: all 0.3s ease;
    }

    .hero-slider {
        width: 100vw;
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
        overflow: hidden;
        background-color: #e0f2fe;
        aspect-ratio: 3 / 1;
    }

    .slider-container {
        display: flex;
        height: 100%;
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .slide {
        min-width: 100%;
        height: 100%;
        position: relative;
    }

    .slide img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
    }

    .slider-dots {
        position: absolute;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 10px;
        z-index: 10;
    }

    .dot {
        width: 12px;
        height: 12px;
        background: rgba(255,255,255,0.5);
        border-radius: 50%;
        cursor: pointer;
        transition: var(--transition);
    }

    .dot.active {
        background: white;
        width: 30px;
        border-radius: 10px;
    }

    .deal-section {
        background-color: #b30000;
        padding: 40px 0;
        width: 100vw;
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
    }

    .deal-container {
        max-width: 1150px;
        margin: 0 auto;
        padding: 0 15px;
    }

    .deal-header {
        text-align: center;
        margin-bottom: 25px;
        color: white;
    }

    .deal-title {
        font-size: 32px;
        font-weight: 900;
        font-style: italic;
        margin-bottom: 10px;
        text-transform: uppercase;
    }

    .deal-box {
        background: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .deal-item {
        border: 1px solid #eee;
        border-radius: 10px;
        padding: 10px;
        text-align: center;
        text-decoration: none;
        color: #333;
        transition: 0.3s;
        background: #fff;
        margin: 0 10px;
    }

    .deal-item:hover { border-color: var(--primary-color); transform: scale(1.02); }
    .deal-item img { width: 100%; height: 160px; object-fit: contain; }
    .deal-price-new { color: var(--primary-color); font-weight: 700; display: block; font-size: 16px; }
    .deal-price-old { color: #999; text-decoration: line-through; font-size: 13px; }

    .btn-deal-hot {
        background: #ff4d4d;
        color: white;
        border: none;
        padding: 6px 12px;
        border-radius: 20px;
        margin-top: 10px;
        font-size: 11px;
        font-weight: bold;
        width: 100%;
    }

    .best-seller-section {
        background-color: #0099ff;
        padding: 40px 0;
        width: 100vw;
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
    }

    .policy-grid {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .policy-item {
        background: white;
        color: #ce6200;
        padding: 8px 15px;
        border-radius: 5px;
        font-weight: bold;
        font-size: 12px;
        text-transform: uppercase;
    }

    .online-badge {
        background: #8b0000;
        color: white;
        font-size: 9px;
        padding: 2px 5px;
        border-radius: 3px;
        display: inline-block;
        margin-bottom: 5px;
        float: left;
    }

    .main-content {
        max-width: 1250px;
        margin: 40px auto;
        padding: 0 15px;
    }

    .page-title {
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 40px;
        text-align: center;
        text-transform: uppercase;
        position: relative;
        padding-bottom: 15px;
    }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 25px;
    }

    .product-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 3px 10px rgba(0,0,0,0.05);
        text-decoration: none;
        color: #333;
        transition: var(--transition);
        border: 1px solid #eee;
        display: flex;
        flex-direction: column;
    }

    .product-card img { width: 100%; height: 220px; object-fit: contain; }

    .sticky-contact {
        position: fixed;
        right: 15px;
        top: 60%;
        display: flex;
        flex-direction: column;
        gap: 12px;
        z-index: 9999;
    }

    .contact-btn {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 22px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        text-decoration: none;
    }

    .zalo { background: #0068ff; }
    .messenger { background: #0084ff; }
    .phone { background: #2ecc71; }

    .slick-prev:before,
    .slick-next:before {
        color: #555;
        font-size: 25px;
    }

    @@media (max-width: 992px) {
        .product-grid { grid-template-columns: repeat(2, 1fr); }
    }
</style>

<section class="hero-slider">
    <div class="slider-container" id="slider">
        <div class="slide"><img src="/images/Home/banner1.png" alt="Banner 1"></div>
        <div class="slide"><img src="/images/Home/banner2.png" alt="Banner 2"></div>
        <div class="slide"><img src="/images/Home/banner3.png" alt="Banner 3"></div>
        <div class="slide"><img src="/images/Home/banner4.png" alt="Banner 4"></div>
    </div>
    <div class="slider-dots">
        <span class="dot active" onclick="currentSlide(0)"></span>
        <span class="dot" onclick="currentSlide(1)"></span>
        <span class="dot" onclick="currentSlide(2)"></span>
        <span class="dot" onclick="currentSlide(3)"></span>
    </div>
</section>

<section class="deal-section">
    <div class="deal-container">
        <div class="deal-header">
            <div class="deal-title">Săn ngay deal xả kho 50%++</div>
            <div style="background: #fff; color: #b30000; display: inline-block; padding: 5px 20px; border-radius: 5px; font-weight: bold; text-transform: uppercase;">Deal hot hôm nay</div>
        </div>
        <div class="deal-box">
            <div class="deal-slider">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model.Take(10))
                    {
                        <a href="/Product/Detail/@item.Id" class="deal-item">
                            <img src="@item.Image" alt="@item.Name" />
                            <div class="deal-name">@item.Name</div>
                            <span class="deal-price-new">@item.Price.ToString("N0") VNĐ</span>
                            <span class="deal-price-old">@((item.Price * 1.2).ToString("N0")) VNĐ</span>
                            <button class="btn-deal-hot">DEAL GIỚI HẠN</button>
                        </a>
                    }
                }
            </div>
        </div>
    </div>
</section>

<section class="best-seller-section">
    <div class="deal-container">
        <div style="text-align:center; color:white; margin-bottom:20px;">
            <h2 style="font-size:35px; font-weight:900; text-transform:uppercase;">TOP SẢN PHẨM BÁN CHẠY</h2>
            <div class="policy-grid">
                <div class="policy-item">Miễn phí vận chuyển toàn quốc</div>
                <div class="policy-item">Bảo hành khung sườn đến 5 năm</div>
                <div class="policy-item">Trả góp 0% lãi suất</div>
            </div>
        </div>
        <div class="deal-box">
            <div class="best-seller-slider">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model.OrderByDescending(x => x.Id).Take(10))
                    {
                        <a href="/Product/Detail/@item.Id" class="deal-item">
                            <span class="online-badge">MUA ONLINE RẺ HƠN</span>
                            <img src="@item.Image" alt="@item.Name" />
                            <div class="deal-name">@item.Name</div>
                            <span class="deal-price-new" style="color:#0099ff">@item.Price.ToString("N0") VNĐ</span>
                            <span class="deal-price-old">@((item.Price * 1.15).ToString("N0")) VNĐ</span>
                            <button class="btn-deal-hot" style="background:#0099ff">XEM CHI TIẾT</button>
                        </a>
                    }
                }
            </div>
        </div>
    </div>
</section>

<div class="main-content">
    <h1 class="page-title">@(ViewBag.CategoryName ?? "Sản phẩm mới nhất")</h1>
    <div class="product-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <a href="/Product/Detail/@item.Id" class="product-card">
                    <img src="@item.Image" alt="@item.Name" />
                    <div class="info" style="padding:15px; text-align:center;">
                        <div class="name" style="font-weight:600; height:40px; overflow:hidden;">@item.Name</div>
                        <div class="price" style="color:var(--secondary-color); font-weight:700;">@item.Price.ToString("N0") VNĐ</div>
                    </div>
                </a>
            }
        }
    </div>
</div>

<div class="sticky-contact">
    <a href="#" class="contact-btn zalo" title="Zalo"><i class="fas fa-comment-dots"></i></a>
    <a href="#" class="contact-btn messenger" title="Messenger"><i class="fab fa-facebook-messenger"></i></a>
    <a href="tel:0123456789" class="contact-btn phone" title="Gọi điện"><i class="fas fa-phone"></i></a>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"></script>

<script>
    let index = 0;
    const slidesContainer = document.getElementById('slider');
    const dots = document.querySelectorAll('.dot');

    function showSlide(n) {
        index = n;
        if (index >= dots.length) index = 0;
        if (index < 0) index = dots.length - 1;
        slidesContainer.style.transform = `translateX(${-index * 100}%)`;
        dots.forEach(d => d.classList.remove('active'));
        dots[index].classList.add('active');
    }

    setInterval(() => showSlide(index + 1), 4000);

    function currentSlide(n) {
        showSlide(n);
    }

    $(document).ready(function() {
        $('.deal-slider, .best-seller-slider').slick({
            infinite: true,
            slidesToShow: 5,
            slidesToScroll: 1,
            autoplay: true,
            autoplaySpeed: 2000,
            arrows: true,
            responsive: [
                { breakpoint: 1024, settings: { slidesToShow: 3 } },
                { breakpoint: 600, settings: { slidesToShow: 2 } }
            ]
        });
    });
</script>
